<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE keyboard3 SYSTEM "https://raw.githubusercontent.com/unicode-org/cldr/main/keyboards/dtd/ldmlKeyboard3.dtd">
<keyboard3 locale="ko" conformsTo="48">
    <info name="Korean Half Qwerty Keyboard" indicator="KO" />
    <!-- 한국어 하프 쿼티 키보드 (조합형 낱자 기반) -->
    <!-- INFO: 조합형으로 구현되었으므로 시스템에서 조합형 입력 및 글꼴을 지원해야 합니다. -->
    <displays>
        <display keyId="base" display="한글" />
        <display keyId="shift" display="\u{21EA}" />
        <display keyId="unshift" display="\u{21EA}'" />
        <display keyId="symbol" display="!#1" />
        <display keyId="symbol-1" display="1/2" />
        <display keyId="symbol-2" display="2/2" />
        <display keyId="bksp" display="⌫" />
        <display keyId="enter" display="⏎" />
        <display keyId="extra" display="🌐" />
        <display keyId="space" display="␣" />
    </displays>

    <keys>
        <key id="ko-i" output="\u{1175}" />
        <key id="ko-area" output="\u{119E}" />
        <key id="ko-eu" output="\u{1173}" />

        <key id="ko-g" output="\u{1100}" />
        <key id="ko-n" output="\u{1102}" />
        <key id="ko-d" output="\u{1103}" />
        <key id="ko-r" output="\u{1105}" />
        <key id="ko-m" output="\u{1106}" />
        <key id="ko-b" output="\u{1107}" />
        <key id="ko-s" output="\u{1109}" />
        <key id="ko-ng" output="\u{110B}" />
        <key id="ko-j" output="\u{110C}" />
        <key id="ko-ch" output="\u{110E}" />
        <key id="ko-k" output="\u{110F}" />
        <key id="ko-t" output="\u{1110}" />
        <key id="ko-p" output="\u{1111}" />
        <key id="ko-h" output="\u{1112}" />
        <key id="ko-gg" output="\u{1101}" />
        <key id="ko-dd" output="\u{1104}" />
        <key id="ko-bb" output="\u{1108}" />
        <key id="ko-ss" output="\u{110A}" />
        <key id="ko-jj" output="\u{110D}" />

        <key id="base" layerId="base" />
        <key id="shift" layerId="touch-shift" />
        <key id="unshift" layerId="base" />
        <key id="symbol" layerId="symbol-1" />
        <key id="symbol-1" layerId="symbol-1" />
        <key id="symbol-2" layerId="symbol-2" />

        <key id="bksp" output="@k3lp:action/backspace" />
        <key id="extra" layerId="english-base" />
        <key id="enter" output="\u{000A}" />
        <key id="space" output="\m{break}" />

        <key id="comma" output="," />
        <key id="period" output="." />
        <key id="semicolon" output=";" />
        <key id="colon" output=":" />
        <key id="question" output="?" />
        <key id="bang" output="!" />
        <key id="at" output="@" />
        <key id="hash" output="#" />
        <key id="dollar" output="$" />
        <key id="percent" output="%" />
        <key id="caret" output="^" />
        <key id="amp" output="&amp;" />
        <key id="asterisk" output="*" />
        <key id="plus" output="+" />
        <key id="minus" output="-" />
        <key id="equal" output="=" />
        <key id="slash" output="/" />
        <key id="open-paren" output="(" />
        <key id="close-paren" output=")" />

        <key id="ko-qs" output="\u{1107}" flickId="ko-qs-flicks" />
        <key id="ko-ws" output="\u{110C}" flickId="ko-ws-flicks" />
        <key id="ko-es" output="\u{1103}" flickId="ko-es-flicks" />
        <key id="ko-rs" output="\u{1100}" flickId="ko-rs-flicks" />
        <key id="ko-ts" output="\u{1109}" flickId="ko-ts-flicks" />
        <key id="ko-as" output="\u{1106}" flickId="ko-as-flicks" />
        <key id="ko-ds" output="\u{110B}" flickId="ko-ds-flicks" />
        <key id="ko-gs" output="\u{1112}" flickId="ko-gs-flicks" />
        <key id="ko-is" output="\u{1175}" flickId="ko-is-flicks" />
        <key id="ko-minuses" output="-" flickId="ko-minuses-flicks" />
        <key id="ko-zs" output="\u{110F}" flickId="ko-zs-flicks" />
        <key id="ko-cs" output="\u{110E}" flickId="ko-cs-flicks" />
        <key id="ko-eus" output="\u{1173}" flickId="ko-eus-flicks" />
        <key id="ko-areas" output="\u{119E}" flickId="ko-areas-flicks" />
    </keys>

    <flicks>
        <flick id="ko-qs-flicks">
            <flickSegment directions="n" keyId="1" />
            <flickSegment directions="w" keyId="ko-b" />
            <flickSegment directions="e" keyId="ko-bb" />
            <flickSegment directions="s" keyId="bang" />
        </flick>
        <flick id="ko-ws-flicks">
            <flickSegment directions="n" keyId="2" />
            <flickSegment directions="w" keyId="ko-j" />
            <flickSegment directions="e" keyId="ko-jj" />
            <flickSegment directions="s" keyId="at" />
        </flick>
        <flick id="ko-es-flicks">
            <flickSegment directions="n" keyId="3" />
            <flickSegment directions="w" keyId="ko-d" />
            <flickSegment directions="e" keyId="ko-dd" />
            <flickSegment directions="s" keyId="hash" />
        </flick>
        <flick id="ko-rs-flicks">
            <flickSegment directions="n" keyId="4" />
            <flickSegment directions="w" keyId="ko-g" />
            <flickSegment directions="e" keyId="ko-gg" />
            <flickSegment directions="s" keyId="dollar" />
        </flick>
        <flick id="ko-ts-flicks">
            <flickSegment directions="n" keyId="5" />
            <flickSegment directions="w" keyId="ko-s" />
            <flickSegment directions="e" keyId="ko-ss" />
            <flickSegment directions="s" keyId="percent" />
        </flick>
        <flick id="ko-as-flicks">
            <flickSegment directions="n" keyId="6" />
            <flickSegment directions="w" keyId="ko-m" />
            <flickSegment directions="e" keyId="ko-n" />
            <flickSegment directions="s" keyId="caret" />
        </flick>
        <flick id="ko-ds-flicks">
            <flickSegment directions="n" keyId="7" />
            <flickSegment directions="w" keyId="ko-ng" />
            <flickSegment directions="e" keyId="ko-r" />
            <flickSegment directions="s" keyId="amp" />
        </flick>
        <flick id="ko-gs-flicks">
            <flickSegment directions="n" keyId="8" />
            <flickSegment directions="w" keyId="ko-h" />
            <flickSegment directions="e" keyId="ko-h" />
            <flickSegment directions="s" keyId="asterisk" />
        </flick>
        <flick id="ko-is-flicks">
            <flickSegment directions="n" keyId="9" />
            <flickSegment directions="w" keyId="ko-i" />
            <flickSegment directions="e" keyId="ko-i" />
            <flickSegment directions="s" keyId="period" />
        </flick>
        <flick id="ko-minuses-flicks">
            <flickSegment directions="n" keyId="0" />
            <flickSegment directions="w" keyId="minus" />
            <flickSegment directions="e" keyId="minus" />
            <flickSegment directions="s" keyId="question" />
        </flick>
    </flicks>
    <flicks>
        <flick id="ko-zs-flicks">
            <flickSegment directions="n" keyId="plus" />
            <flickSegment directions="w" keyId="ko-k" />
            <flickSegment directions="e" keyId="ko-t" />
            <flickSegment directions="s" keyId="equal" />
        </flick>
        <flick id="ko-cs-flicks">
            <flickSegment directions="n" keyId="semicolon" />
            <flickSegment directions="w" keyId="ko-ch" />
            <flickSegment directions="e" keyId="ko-p" />
            <flickSegment directions="s" keyId="comma" />
        </flick>
        <flick id="ko-eus-flicks">
            <flickSegment directions="n" keyId="colon" />
            <flickSegment directions="w" keyId="ko-eu" />
            <flickSegment directions="e" keyId="ko-eu" />
            <flickSegment directions="s" keyId="open-paren" />
        </flick>
        <flick id="ko-areas-flicks">
            <flickSegment directions="n" keyId="slash" />
            <flickSegment directions="w" keyId="ko-area" />
            <flickSegment directions="e" keyId="ko-area" />
            <flickSegment directions="s" keyId="close-paren" />
        </flick>
    </flicks>

    <layers formId="touch">
        <layer id="base">
            <row keys="ko-qs ko-ws ko-es ko-rs ko-ts" />
            <row keys="ko-as ko-ds ko-gs ko-is ko-minuses" />
            <row keys="ko-zs ko-cs ko-eus ko-areas bksp" />
            <row keys="extra symbol space gap enter" />
        </layer>
    </layers>

    <variables>
        <set id="cho"
            value="\u{1100} \u{1101} \u{1102} \u{1103} \u{1104} \u{1105} \u{1106} \u{1107} \u{1108} \u{1109} \u{110A} \u{110B} \u{110C} \u{110D} \u{110E} \u{110F} \u{1110} \u{1111} \u{1112}" />
        <set id="jung"
            value="\u{1161} \u{1162} \u{1163} \u{1164} \u{1165} \u{1166} \u{1167} \u{1168} \u{1169} \u{116A} \u{116B} \u{116C} \u{116D} \u{116E} \u{116F} \u{1170} \u{1171} \u{1172} \u{1173} \u{1174} \u{1175} \u{119E}" />
        <set id="cho_for_jong"
            value="\u{1100} \u{1102} \u{1103} \u{1107} \u{1109} \u{110C} \u{110B}" />
        <set id="jong_mapped" value="\u{11A8} \u{11AB} \u{11AE} \u{11B8} \u{11BA} \u{11BD} \u{11BC}" />
        <set id="jong_single"
            value="\u{11A8} \u{11A9} \u{11AB} \u{11AE} \u{11AF} \u{11B7} \u{11B8} \u{11BA} \u{11BB} \u{11BC} \u{11BD} \u{11BE} \u{11BF} \u{11C0} \u{11C1} \u{11C2}" />
        <set id="cho_mapped"
            value="\u{1100} \u{1101} \u{1102} \u{1103} \u{1105} \u{1106} \u{1107} \u{1109} \u{110A} \u{110B} \u{110C} \u{110E} \u{110F} \u{1110} \u{1111} \u{1112}" />
    </variables>

    <transforms type="simple">
        <transformGroup>
            <!-- 모음 합성 -->
            <transform from="\u{119E}\u{119E}" to="\u{11A2}" />
            <transform from="\u{1175}\u{119E}" to="\u{1161}" />
            <transform from="\u{1161}\u{119E}" to="\u{1163}" />
            <transform from="\u{119E}\u{1175}" to="\u{1165}" />
            <transform from="\u{11A2}\u{1175}" to="\u{1167}" />
            <transform from="\u{119E}\u{1173}" to="\u{1169}" />
            <transform from="\u{11A2}\u{1173}" to="\u{116D}" />
            <transform from="\u{1173}\u{119E}" to="\u{116E}" />
            <transform from="\u{116E}\u{119E}" to="\u{1172}" />
            <transform from="\u{1161}\u{1175}" to="\u{1162}" />
            <transform from="\u{1163}\u{1175}" to="\u{1164}" />
            <transform from="\u{1165}\u{1175}" to="\u{1166}" />
            <transform from="\u{1167}\u{1175}" to="\u{1168}" />
            <transform from="\u{1169}\u{1175}" to="\u{116C}" />
            <transform from="\u{116C}\u{119E}" to="\u{116A}" />
            <transform from="\u{116A}\u{1175}" to="\u{116B}" />
            <transform from="\u{116E}\u{1175}" to="\u{1171}" />
            <transform from="\u{1172}\u{1175}" to="\u{116F}" />
            <transform from="\u{116F}\u{1175}" to="\u{1170}" />
            <transform from="\u{1173}\u{1175}" to="\u{1174}" />

            <!-- 초성 순환 -->
            <!-- ㄱ -> ㄲ -> ㅋ -> ㄲ -->
            <transform from="\u{1100}\u{1100}" to="\u{1101}" />
            <transform from="\u{1101}\u{1100}" to="\u{110F}" />
            <transform from="\u{110F}\u{1100}" to="\u{1101}" />

            <!-- ㄷ -> ㄸ -> ㅌ -> ㄸ -->
            <transform from="\u{1103}\u{1103}" to="\u{1104}" />
            <transform from="\u{1104}\u{1103}" to="\u{1110}" />
            <transform from="\u{1110}\u{1103}" to="\u{1104}" />
            <!-- ㅂ -> ㅃ -> ㅍ -> ㅃ -->
            <transform from="\u{1107}\u{1107}" to="\u{1108}" />
            <transform from="\u{1108}\u{1107}" to="\u{1111}" />
            <transform from="\u{1111}\u{1107}" to="\u{1108}" />

            <!-- ㅈ -> ㅉ -> ㅊ -> ㅉ -->
            <transform from="\u{110C}\u{110C}" to="\u{110D}" />
            <transform from="\u{110D}\u{110C}" to="\u{110E}" />
            <transform from="\u{110E}\u{110C}" to="\u{110D}" />

            <!-- ㅅ -> ㅆ -> ㅅ -->
            <transform from="\u{1109}\u{1109}" to="\u{110A}" />
            <transform from="\u{110A}\u{1109}" to="\u{1109}" />

            <!-- ㅇ -> ㅎ -> ㅇ -->
            <transform from="\u{110B}\u{110B}" to="\u{1112}" />
            <transform from="\u{1112}\u{110B}" to="\u{110B}" />

            <!-- 종성 자리 자음(초성)을 종성으로 이동 -->
            <transform from="($[cho])($[jung])($[cho_for_jong])" to="$1$2$[3:jong_mapped]" />
            <!-- 종성 순환에서 초성으로 온 쌍자음 뒤에 중성이 붙으면 순환 중단 -->
            <transform from="\m{doubled}($[jung])" to="$1" />

            <!--  종성 순환 -->
            <!-- ᆨ -> ᆩ -> ᆿ -> ᆩ -->
            <transform from="\u{11A8}\u{1100}" to="\u{11A9}" />
            <transform from="\u{11A9}\u{1100}" to="\u{11BF}" />
            <transform from="\u{11BF}\u{1100}" to="\u{11A9}" />

            <!-- ᆺ -> ᆻ -> ᆺ -->
            <transform from="\u{11BA}\u{1109}" to="\u{11BB}" />
            <transform from="\u{11BB}\u{1109}" to="\u{11BA}" />

            <!-- ᆼ -> ᇂ -> ᆼ -->
            <transform from="\u{11BC}\u{110B}" to="\u{11C2}" />
            <transform from="\u{11C2}\u{110B}" to="\u{11BC}" />

            <!-- ᆮ -> ㄸ(초성) -> ᇀ -> ㄸ(초성) -->
            <transform from="\u{11AE}\u{1103}" to="\u{1104}\m{doubled}" />
            <transform from="\u{11C0}\u{1103}" to="\u{1104}\m{doubled}" />
            <transform from="\u{1104}\m{doubled}\u{1103}" to="\u{1110}" />

            <!-- ᆸ -> ㅃ(초성) -> ᇁ -> ㅃ(초성) -->
            <transform from="\u{11B8}\u{1107}" to="\u{1108}\m{doubled}" />
            <transform from="\u{11C1}\u{1107}" to="\u{1108}\m{doubled}" />
            <transform from="\u{1108}\m{doubled}\u{1107}" to="\u{1111}" />

            <!-- ᆽ -> ㅉ(초성) -> ᆾ -> ㅉ(초성) -->
            <transform from="\u{11BD}\u{110C}" to="\u{110D}\m{doubled}" />
            <transform from="\u{11BE}\u{110C}" to="\u{110D}\m{doubled}" />
            <transform from="\u{110D}\m{doubled}\u{110C}" to="\u{110E}" />

            <!-- 이중 종성 -->
            <transform from="\u{11A8}\u{1109}" to="\u{11AA}" />
            <transform from="\u{11AB}\u{110C}" to="\u{11AC}" />
            <transform from="\u{11AB}\u{1112}" to="\u{11AD}" />
            <transform from="\u{11AF}\u{1100}" to="\u{11B0}" />
            <transform from="\u{11AF}\u{1106}" to="\u{11B1}" />
            <transform from="\u{11AF}\u{1107}" to="\u{11B2}" />
            <transform from="\u{11AF}\u{1109}" to="\u{11B3}" />
            <transform from="\u{11AF}\u{1110}" to="\u{11B4}" />
            <transform from="\u{11AF}\u{1111}" to="\u{11B5}" />
            <transform from="\u{11AF}\u{1112}" to="\u{11B6}" />
            <transform from="\u{11B8}\u{1109}" to="\u{11B9}" />

            <!-- 순환에 의한 이중 종성 해제 -->
            <transform from="\u{11AA}\u{1109}" to="\u{11A8}\u{110A}\m{doubled}" />
            <transform from="\u{11AC}\u{110C}" to="\u{11AB}\u{110D}\m{doubled}" />
            <transform from="\u{11AD}\u{110B}" to="\u{11AB}\u{110B}\m{doubled}" />
            <transform from="\u{11B0}\u{1100}" to="\u{11AF}\u{1101}\m{doubled}" />
            <transform from="\u{11B1}\u{1106}" to="\u{11AF}\u{1106}\m{doubled}" />
            <transform from="\u{11B2}\u{1107}" to="\u{11AF}\u{1108}\m{doubled}" />
            <transform from="\u{11B3}\u{1109}" to="\u{11AF}\u{110A}\m{doubled}" />
            <transform from="\u{11B4}\u{1103}" to="\u{11AF}\u{1104}\m{doubled}" />
            <transform from="\u{11B5}\u{1107}" to="\u{11AF}\u{1108}\m{doubled}" />
            <transform from="\u{11B6}\u{110B}" to="\u{11AF}\u{110B}\m{doubled}" />
            <transform from="\u{11B9}\u{1109}" to="\u{11B8}\u{110A}\m{doubled}" />

            <!-- 연음 -->
            <transform from="($[jong_single])($[jung])" to="$[1:cho_mapped]$2" />
            <transform from="\u{11AA}($[jung])" to="\u{11A8}\u{1109}$1" /> <!-- ㄳ → ㄱㅅ -->
            <transform from="\u{11AC}($[jung])" to="\u{11AB}\u{110C}$1" /> <!-- ㄵ → ㄴㅈ -->
            <transform from="\u{11AD}($[jung])" to="\u{11AB}\u{1112}$1" /> <!-- ㄶ → ㄴㅎ -->
            <transform from="\u{11B0}($[jung])" to="\u{11AF}\u{1100}$1" /> <!-- ㄺ → ㄹㄱ -->
            <transform from="\u{11B1}($[jung])" to="\u{11AF}\u{1106}$1" /> <!-- ㄻ → ㄹㅁ -->
            <transform from="\u{11B2}($[jung])" to="\u{11AF}\u{1107}$1" /> <!-- ㄼ → ㄹㅂ -->
            <transform from="\u{11B3}($[jung])" to="\u{11AF}\u{1109}$1" /> <!-- ㄽ → ㄹㅅ -->
            <transform from="\u{11B4}($[jung])" to="\u{11AF}\u{1110}$1" /> <!-- ㄾ → ㄹㅌ -->
            <transform from="\u{11B5}($[jung])" to="\u{11AF}\u{1111}$1" /> <!-- ㄿ → ㄹㅍ -->
            <transform from="\u{11B6}($[jung])" to="\u{11AF}\u{1112}$1" /> <!-- ㅀ → ㄹㅎ -->
            <transform from="\u{11B9}($[jung])" to="\u{11B8}\u{1109}$1" /> <!-- ㅄ → ㅂㅅ -->

            <!-- 스페이스 1회로 조합 끊기, 2회로 공백 -->
            <transform from="\m{break}\m{break}" to=" " />
            <transform from=" \m{break}" to="  " />
        </transformGroup>
    </transforms>
</keyboard3>