<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE keyboard3 SYSTEM "https://raw.githubusercontent.com/unicode-org/cldr/main/keyboards/dtd/ldmlKeyboard3.dtd">
<keyboard3 locale="ko" conformsTo="48">
    <info name="Korean DanMoEum Standard" indicator="KO"/>
    <!-- 한국어 단모음 키보드 -->
    <displays>
        <display keyId="base" display="한글" />
        <display keyId="shift" display="\u{21EA}" />
        <display keyId="unshift" display="\u{21EA}'" />
        <display keyId="symbol" display="!#1" />
        <display keyId="symbol-1" display="1/2" />
        <display keyId="symbol-2" display="2/2" />
        <display keyId="bksp" display="⌫" />
        <display keyId="enter" display="⏎" />
        <display keyId="extra" display="한/영" />
    </displays>

    <keys>
        <key id="ko-q" output="ㅂ"/>
        <key id="ko-w" output="ㅈ"/>
        <key id="ko-e" output="ㄷ"/>
        <key id="ko-r" output="ㄱ"/>
        <key id="ko-t" output="ㅅ"/>
        <key id="ko-y" output="ㅛ"/>
        <key id="ko-u" output="ㅕ"/>
        <key id="ko-i" output="ㅑ"/>
        <key id="ko-o" output="ㅐ"/>
        <key id="ko-p" output="ㅔ"/>
        
        <key id="ko-a" output="ㅁ"/>
        <key id="ko-s" output="ㄴ"/>
        <key id="ko-d" output="ㅇ"/>
        <key id="ko-f" output="ㄹ"/>
        <key id="ko-g" output="ㅎ"/>
        <key id="ko-h" output="ㅗ"/>
        <key id="ko-j" output="ㅓ"/>
        <key id="ko-k" output="ㅏ"/>
        <key id="ko-l" output="ㅣ"/>
        
        <key id="ko-z" output="ㅋ"/>
        <key id="ko-x" output="ㅌ"/>
        <key id="ko-c" output="ㅊ"/>
        <key id="ko-v" output="ㅍ"/>
        <key id="ko-b" output="ㅠ"/>
        <key id="ko-n" output="ㅜ"/>
        <key id="ko-m" output="ㅡ"/>
        
        <key id="ko-Q" output="ㅃ"/>
        <key id="ko-W" output="ㅉ"/>
        <key id="ko-E" output="ㄸ"/>
        <key id="ko-R" output="ㄲ"/>
        <key id="ko-T" output="ㅆ"/>
        <key id="ko-O" output="ㅒ"/>
        <key id="ko-P" output="ㅖ"/>

        <key id="base" layerId="base" />
        <key id="shift" layerId="touch-shift" />
        <key id="unshift" layerId="base" />
        <key id="symbol" layerId="symbol-1" />
        <key id="symbol-1" layerId="symbol-1" />
        <key id="symbol-2" layerId="symbol-2" />
        
        <key id="bksp" output=""/>
        <key id="extra" layerId="english-base" />
        <key id="enter" output=""/>
        <key id="space" output=" " stretch="true" />
        <key id="comma" output="," />
        <key id="period" output="." />

        <key id="1" output="1" />
        <key id="2" output="2" />
        <key id="3" output="3" />
        <key id="4" output="4" />
        <key id="5" output="5" />
        <key id="6" output="6" />
        <key id="7" output="7" />
        <key id="8" output="8" />
        <key id="9" output="9" />
        <key id="0" output="0" />

        <key id="bang" output="!" />
        <key id="at" output="@" />
        <key id="hash" output="#" />
        <key id="dollar" output="$" />
        <key id="percent" output="%" />
        <key id="caret" output="^" />
        <key id="amp" output="&amp;" />
        <key id="asterisk" output="*" />
        <key id="open-paren" output="(" />
        <key id="close-paren" output=")" />
        <key id="lt" output="&lt;" />
        <key id="gt" output="&gt;" />
    </keys>
    
    <layers formId="touch">
        <layer id="base">
            <row keys="ko-q ko-w ko-e ko-r ko-t ko-h ko-o ko-p" />
            <row keys="ko-a ko-s ko-d ko-f ko-g ko-j ko-k ko-l" />
            <row keys="ko-z ko-x ko-c ko-v ko-n ko-m bksp" />
            <row keys="symbol comma extra space period enter" />
        </layer>
    </layers>

    <transforms type="simple">
        <!-- TODO: 이미 조합된 자모에 대해서는 미지원. IME 대응 필요 -->
        <transformGroup>
            <transform from="ㅂㅂ" to="ㅃ" />
            <transform from="ㅈㅈ" to="ㅉ" />
            <transform from="ㄷㄷ" to="ㄸ" />
            <transform from="ㄱㄱ" to="ㄲ" />
            <transform from="ㅅㅅ" to="ㅆ" />
        </transformGroup>
        <transformGroup>
            <transform from="ㅗㅗ" to="ㅛ" />
            <transform from="ㅓㅓ" to="ㅕ" />
            <transform from="ㅏㅏ" to="ㅑ" />
            <transform from="ㅜㅜ" to="ㅠ" />
            <transform from="ㅐㅐ" to="ㅒ" />
            <transform from="ㅔㅔ" to="ㅖ" />
        </transformGroup>
    </transforms>
</keyboard3>
